interface UnitLibrary : Library {
    companion object {
        val INSTANCE: UnitLibrary = QuestLibrary.getLibrary(UnitLibrary::class.java)
    }

    fun questpdf__unit__convert_to_points(value: Float, unit: LengthUnit): Float;
}

data class PageSize(val width: Float, val height: Float) {
    /**
     * Defines the physical dimensions (width and height) of a page.
     *
     * Commonly used page sizes are available in the PageSizes object.
     * Change page orientation with the portrait() and landscape() methods.
     */
    constructor(width: Float, height: Float, unit: LengthUnit = LengthUnit.Point) : this(
        width = validated(width, "width", unit),
        height = validated(height, "height", unit)
    )

    /** Sets page size to portrait orientation, making width smaller than height. */
    fun portrait(): PageSize = PageSize(
        width = minOf(width, height),
        height = maxOf(width, height)
    )

    /** Sets page size to landscape orientation, making width bigger than height. */
    fun landscape(): PageSize = PageSize(
        width = maxOf(width, height),
        height = minOf(width, height)
    )

    companion object {
        private fun validated(value: Float, name: String, unit: LengthUnit): Float {
            require(value >= 0) { "Page $name must be greater than 0." }
            return UnitLibrary.INSTANCE.questpdf__unit__convert_to_points(value, unit)
        }
    }
}


